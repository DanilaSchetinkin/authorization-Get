<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SchetinkinDemo06032026.MainWindow"
        Title="SchetinkinDemo06032026">
    <Grid RowDefinitions="*,*,*"
          ColumnDefinitions="*,*,*"
          ShowGridLines="True">
        <TextBlock Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Right" >Логин</TextBlock>
        <TextBox Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="200" Name="LoginBox"></TextBox>
        <TextBlock Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Right">Пароль</TextBlock>
        <TextBox Name="PasswordBox" Width="200" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"></TextBox>
		
			<Button Click="Button_Click" Grid.Row="2" Grid.Column="1" Content="Войти"></Button>
    </Grid>
</Window>
